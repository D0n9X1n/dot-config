{
  "name": "Apollo",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#141617",
    "editor.foreground": "#ebdbb2",
    "editorCursor.foreground": "#ebdbb2",
    "editor.selectionBackground": "#3c3836",
    "editor.lineHighlightBackground": "#1d2021",
    "editorLineNumber.foreground": "#928374",
    "editorLineNumber.activeForeground": "#fabd2f",
    "editorWhitespace.foreground": "#3c3836",
    "editorIndentGuide.background1": "#1d2021",
    "editorIndentGuide.activeBackground1": "#3c3836",
    "editorBracketMatch.background": "#3c3836",
    "editorBracketMatch.border": "#fabd2f",
    "editor.findMatchBackground": "#fabd2f55",
    "editor.findMatchHighlightBackground": "#fabd2f33",
    "editor.wordHighlightBackground": "#3c383680",
    "editor.wordHighlightStrongBackground": "#3c3836",
    "editorGutter.modifiedBackground": "#fabd2f",
    "editorGutter.addedBackground": "#b8bb26",
    "editorGutter.deletedBackground": "#fb4934",
    "editorError.foreground": "#fb4934",
    "editorWarning.foreground": "#fabd2f",
    "editorInfo.foreground": "#83a598",
    "editorHint.foreground": "#8ec07c",

    "activityBar.background": "#141617",
    "activityBar.foreground": "#d5c4a1",
    "activityBar.inactiveForeground": "#928374",
    "activityBar.activeBorder": "#fabd2f",
    "activityBarBadge.background": "#fabd2f",
    "activityBarBadge.foreground": "#141617",

    "sideBar.background": "#141617",
    "sideBar.foreground": "#d5c4a1",
    "sideBarTitle.foreground": "#ebdbb2",
    "sideBarSectionHeader.background": "#1d2021",
    "sideBarSectionHeader.foreground": "#ebdbb2",

    "statusBar.background": "#1d2021",
    "statusBar.foreground": "#d5c4a1",
    "statusBar.debuggingBackground": "#b16286",
    "statusBar.debuggingForeground": "#ebdbb2",
    "statusBar.noFolderBackground": "#1d2021",
    "statusBarItem.remoteBackground": "#458588",
    "statusBarItem.remoteForeground": "#ebdbb2",

    "titleBar.activeBackground": "#141617",
    "titleBar.activeForeground": "#ebdbb2",
    "titleBar.inactiveBackground": "#141617",
    "titleBar.inactiveForeground": "#928374",

    "tab.activeBackground": "#141617",
    "tab.activeForeground": "#fabd2f",
    "tab.inactiveBackground": "#141617",
    "tab.inactiveForeground": "#928374",
    "tab.activeBorderTop": "#fabd2f",
    "tab.border": "#1d2021",
    "editorGroupHeader.tabsBackground": "#141617",
    "editorGroup.border": "#1d2021",

    "panel.background": "#141617",
    "panel.border": "#1d2021",
    "panelTitle.activeForeground": "#fabd2f",
    "panelTitle.inactiveForeground": "#928374",

    "terminal.background": "#141617",
    "terminal.foreground": "#ebdbb2",
    "terminalCursor.background": "#141617",
    "terminalCursor.foreground": "#ebdbb2",
    "terminal.ansiBlack": "#1d2021",
    "terminal.ansiRed": "#cc241d",
    "terminal.ansiGreen": "#98971a",
    "terminal.ansiYellow": "#d79921",
    "terminal.ansiBlue": "#458588",
    "terminal.ansiMagenta": "#b16286",
    "terminal.ansiCyan": "#689d6a",
    "terminal.ansiWhite": "#d4be98",
    "terminal.ansiBrightBlack": "#928374",
    "terminal.ansiBrightRed": "#fb4934",
    "terminal.ansiBrightGreen": "#b8bb26",
    "terminal.ansiBrightYellow": "#fabd2f",
    "terminal.ansiBrightBlue": "#83a598",
    "terminal.ansiBrightMagenta": "#d3869b",
    "terminal.ansiBrightCyan": "#8ec07c",
    "terminal.ansiBrightWhite": "#ebdbb2",

    "input.background": "#1d2021",
    "input.foreground": "#ebdbb2",
    "input.border": "#3c3836",
    "inputOption.activeBorder": "#fabd2f",
    "dropdown.background": "#1d2021",
    "dropdown.foreground": "#ebdbb2",
    "dropdown.border": "#3c3836",
    "list.activeSelectionBackground": "#3c3836",
    "list.activeSelectionForeground": "#fabd2f",
    "list.inactiveSelectionBackground": "#3c3836",
    "list.inactiveSelectionForeground": "#ebdbb2",
    "list.hoverBackground": "#1d2021",
    "list.focusBackground": "#3c3836",
    "list.highlightForeground": "#fabd2f",

    "button.background": "#458588",
    "button.foreground": "#ebdbb2",
    "button.hoverBackground": "#83a598",

    "scrollbarSlider.background": "#3c383680",
    "scrollbarSlider.hoverBackground": "#3c3836",
    "scrollbarSlider.activeBackground": "#928374",

    "badge.background": "#fabd2f",
    "badge.foreground": "#141617",

    "diffEditor.insertedTextBackground": "#b8bb2622",
    "diffEditor.removedTextBackground": "#fb493422",

    "gitDecoration.modifiedResourceForeground": "#fabd2f",
    "gitDecoration.deletedResourceForeground": "#fb4934",
    "gitDecoration.untrackedResourceForeground": "#b8bb26",
    "gitDecoration.ignoredResourceForeground": "#928374",
    "gitDecoration.conflictingResourceForeground": "#d3869b",

    "peekView.border": "#fabd2f",
    "peekViewEditor.background": "#1d2021",
    "peekViewResult.background": "#1d2021",

    "notificationCenter.border": "#3c3836",
    "notifications.background": "#1d2021",
    "notifications.foreground": "#ebdbb2",

    "focusBorder": "#fabd2f",
    "foreground": "#ebdbb2"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#928374", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted"], "settings": { "foreground": "#b8bb26" } },
    { "scope": ["constant.numeric", "constant.language", "constant.character"], "settings": { "foreground": "#d3869b" } },
    { "scope": ["variable", "variable.other"], "settings": { "foreground": "#ebdbb2" } },
    { "scope": ["variable.language", "variable.parameter"], "settings": { "foreground": "#ebdbb2" } },
    { "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"], "settings": { "foreground": "#fb4934" } },
    { "scope": ["keyword.operator", "punctuation.separator"], "settings": { "foreground": "#d5c4a1" } },
    { "scope": ["entity.name.function", "support.function", "meta.function-call"], "settings": { "foreground": "#fabd2f" } },
    { "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"], "settings": { "foreground": "#fabd2f" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#8ec07c" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#fabd2f" } },
    { "scope": ["punctuation"], "settings": { "foreground": "#d5c4a1" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#fabd2f", "fontStyle": "bold" } },
    { "scope": ["markup.bold"], "settings": { "fontStyle": "bold" } },
    { "scope": ["markup.italic"], "settings": { "fontStyle": "italic" } },
    { "scope": ["markup.inserted"], "settings": { "foreground": "#b8bb26" } },
    { "scope": ["markup.deleted"], "settings": { "foreground": "#fb4934" } },
    { "scope": ["markup.changed"], "settings": { "foreground": "#fabd2f" } },
    { "scope": ["invalid", "invalid.illegal"], "settings": { "foreground": "#fb4934", "fontStyle": "bold" } }
  ]
}
